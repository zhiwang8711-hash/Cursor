"""
AFA 量化框架 - Layer 3: 个股结构层 (Alpha策略)
===============================================
核心选股因子设计与评分系统
"""

import numpy as np
import pandas as pd
from typing import Dict, List, Optional
from collections import defaultdict

from config import STOCK_SCORING_CONFIG
from data_loader import DataLoader
from utils import gaussian_value, get_historical_mode


class AlphaStrategy:
    """Alpha 选股策略器。"""

    def __init__(self, data_loader: Optional[DataLoader] = None):
        self.config = STOCK_SCORING_CONFIG
        self.data_loader = data_loader or DataLoader()
        self.height_history = defaultdict(list)

    def calculate_height_value(self, current_height: int, historical_heights: Optional[List[int]] = None) -> float:
        sigma = self.config['height_value']['sigma']
        main_height = get_historical_mode(pd.Series(historical_heights), 60) if historical_heights else 3
        return gaussian_value(current_height, main_height, sigma)

    def calculate_leader_index(
        self,
        stock_code: str,
        limit_up_amount: float,
        total_amount: float,
        lhb_institutions: int = 0,
        follow_stocks: int = 0,
    ) -> float:
        weights = self.config['leader_index']
        seal_ratio = (limit_up_amount / total_amount * 100) if total_amount > 0 else 0
        leader_index = (
            weights['seal_order_weight'] * seal_ratio
            + weights['lhb_inst_weight'] * lhb_institutions
            + weights['follow_stock_weight'] * follow_stocks
        )
        return float(np.clip(leader_index, 0, 100))

    def calculate_comprehensive_score(self, df: pd.DataFrame, market_adjustment: Optional[Dict] = None) -> pd.DataFrame:
        if df.empty:
            return df

        df = df.copy()
        market_adjustment = market_adjustment or {}

        # 标准化常见数值字段，降低脏数据影响
        for col in ['连板数', '换手率', '现价', '成交额', '涨跌幅', '振幅', '开盘涨跌幅', '封单额', '炸板次数']:
            if col in df.columns:
                df[col] = pd.to_numeric(df[col], errors='coerce')

        df['基础分'] = 50.0
        df['高度价值分'] = df['连板数'].apply(lambda x: self.calculate_height_value(int(x)) * 100 if pd.notna(x) else 50.0) if '连板数' in df.columns else 50.0
        df['换手率分'] = df['换手率'].apply(self._score_turnover_range) if '换手率' in df.columns else 50.0
        df['价格分'] = df['现价'].apply(self._score_price_range) if '现价' in df.columns else 50.0
        df['成交额分'] = df['成交额'].apply(self._score_amount_range) if '成交额' in df.columns else 50.0
        df['一字板分'] = df.apply(self._score_ziban, axis=1) if ('是否一字板' in df.columns or '涨跌幅' in df.columns) else 50.0
        df['龙头辨识分'] = df.apply(self._score_leader_proxy, axis=1)
        df['趋势强度分'] = df.apply(self._score_trend_strength, axis=1)
        df['开盘质量分'] = df.apply(self._score_open_quality, axis=1)
        df['封板稳定分'] = df.apply(self._score_board_stability, axis=1)

        # 打板模型加入可交易性约束：先惩罚再排序，避免高分低可交易样本
        df['交易惩罚分'], df['可交易标记'] = self._calc_tradeability(df)

        weights = self._get_dynamic_weights(market_adjustment.get('market_regime', 'neutral'))
        df['综合评分'] = sum(df[col] * weight for col, weight in weights.items() if col in df.columns)
        df['综合评分'] = df['综合评分'] - df['交易惩罚分']

        alpha = float(market_adjustment.get('alpha_multiplier', 1.0))
        df['综合评分'] = df['综合评分'] * alpha

        emotion_index = market_adjustment.get('emotion_index')
        if emotion_index is not None:
            emotion_boost = float(np.clip(0.95 + emotion_index * 0.1, 0.90, 1.05))
            df['综合评分'] = df['综合评分'] * emotion_boost

        if '主线加分' in df.columns:
            df['综合评分'] = df['综合评分'] + df['主线加分'].fillna(0)

        return df

    def _get_dynamic_weights(self, market_regime: str) -> Dict[str, float]:
        base_weights = self.config.get('factor_weights', {}).copy()
        regime_adj = self.config.get('regime_weight_adjustments', {}).get(market_regime, {})
        for factor, multiplier in regime_adj.items():
            if factor in base_weights:
                base_weights[factor] *= multiplier
        total = sum(base_weights.values())
        return {k: v / total for k, v in base_weights.items()} if total > 0 else base_weights

    def _calc_tradeability(self, df: pd.DataFrame) -> pd.Series:
        cfg = self.config.get('execution_guardrails', {})
        min_amount = cfg.get('min_amount', 1.5e8)
        max_amp = cfg.get('max_amplitude', 14.0)
        turnover_low = cfg.get('min_turnover', 2.0)
        turnover_high = cfg.get('max_turnover', 40.0)

        penalties = pd.Series(0.0, index=df.index)
        tradable = pd.Series(1, index=df.index)

        if '成交额' in df.columns:
            low_amount = df['成交额'].fillna(0) < min_amount
            penalties = penalties + low_amount.astype(float) * 12
            tradable = tradable * (~low_amount).astype(int)

        if '振幅' in df.columns:
            high_amp = df['振幅'].fillna(0) > max_amp
            penalties = penalties + high_amp.astype(float) * 8
            tradable = tradable * (~high_amp).astype(int)

        if '换手率' in df.columns:
            bad_turnover = (df['换手率'].fillna(0) < turnover_low) | (df['换手率'].fillna(0) > turnover_high)
            penalties = penalties + bad_turnover.astype(float) * 6

        return penalties, tradable

    def _score_turnover_range(self, turnover: float) -> float:
        if pd.isna(turnover):
            return 50
        if 3 <= turnover <= 15:
            return 100
        if turnover < 3:
            return 50 + turnover / 3 * 50
        if turnover <= 30:
            return 100 - (turnover - 15) / 15 * 30
        return 20

    def _score_price_range(self, price: float) -> float:
        if pd.isna(price):
            return 50
        if 10 <= price <= 50:
            return 100
        if price < 10:
            return 50 + price / 10 * 50
        if price <= 100:
            return 100 - (price - 50) / 50 * 30
        return 40

    def _score_amount_range(self, amount: float) -> float:
        if pd.isna(amount) or amount <= 0:
            return 50
        if 1e8 <= amount <= 5e8:
            return 100
        if amount < 1e8:
            return 50 + (amount / 1e8) * 50
        if amount <= 1e9:
            return 100 - (amount - 5e8) / 5e8 * 20
        return 60

    def _score_ziban(self, row: pd.Series) -> float:
        if '是否一字板' in row and pd.notna(row['是否一字板']):
            return 85 if bool(row['是否一字板']) else 50
        if '涨跌幅' in row and pd.notna(row['涨跌幅']):
            return 80 if float(row['涨跌幅']) > 9.5 else 50
        return 50

    def _score_leader_proxy(self, row: pd.Series) -> float:
        seal_amt = float(row.get('封单额', 0) or 0)
        total_amt = float(row.get('成交额', 0) or 0)
        lhb_inst = int(row.get('龙虎榜机构数', 0) or 0)
        follow_cnt = int(row.get('跟风涨停数', 0) or 0)

        if seal_amt > 0 or lhb_inst > 0 or follow_cnt > 0:
            return self.calculate_leader_index(str(row.get('代码', 'UNKNOWN')), seal_amt, total_amt, lhb_inst, follow_cnt)

        height = float(row.get('连板数', 1) or 1)
        amount = float(row.get('成交额', 0) or 0)
        height_score = np.clip(height / 5 * 100, 0, 100)
        liquidity_score = np.clip(amount / 5e8 * 100, 0, 100)
        return 0.6 * height_score + 0.4 * liquidity_score

    def _score_trend_strength(self, row: pd.Series) -> float:
        pct_chg = float(row.get('涨跌幅', 0) or 0)
        amplitude = float(row.get('振幅', 0) or 0)
        chg_score = np.clip((pct_chg + 2) / 12 * 100, 0, 100)
        amp_score = np.clip(100 - (amplitude / 15 * 100), 20, 100)
        return 0.65 * chg_score + 0.35 * amp_score

    def _score_open_quality(self, row: pd.Series) -> float:
        """开盘质量：优秀打板模型通常偏好高开不过热 + 开盘后承接稳定。"""
        open_pct = float(row.get('开盘涨跌幅', np.nan))
        if pd.isna(open_pct):
            return 55
        if 1 <= open_pct <= 5:
            return 95
        if -1 <= open_pct < 1:
            return 75
        if 5 < open_pct <= 8:
            return 70
        return 45

    def _score_board_stability(self, row: pd.Series) -> float:
        """封板稳定性：炸板少、振幅可控的标的更易次日溢价。"""
        break_count = float(row.get('炸板次数', 0) or 0)
        amplitude = float(row.get('振幅', 0) or 0)

        break_penalty = np.clip(break_count * 18, 0, 60)
        amp_penalty = np.clip(amplitude * 2.0, 0, 40)
        return float(np.clip(100 - break_penalty - amp_penalty, 20, 100))

    def rank_stocks(self, df: pd.DataFrame, top_n: int = 10) -> pd.DataFrame:
        if df.empty:
            return df
        if '可交易标记' in df.columns:
            df = df.sort_values(['可交易标记', '综合评分'], ascending=[False, False])
        else:
            df = df.sort_values('综合评分', ascending=False)
        return df.head(top_n)

    def select_with_height_limit(self, df: pd.DataFrame, max_height: int) -> pd.DataFrame:
        if df.empty or '连板数' not in df.columns:
            return df
        return df[df['连板数'] <= max_height].copy()

    def apply_dynamic_filter(self, df: pd.DataFrame, market_regime: str) -> pd.DataFrame:
        if df.empty:
            return df

        threshold_cfg = self.config.get('regime_score_floor', {'strong': 50, 'neutral': 55, 'weak': 60})
        floor = threshold_cfg.get(market_regime, threshold_cfg.get('neutral', 55))

        df_filtered = df[df['综合评分'] >= floor].copy() if '综合评分' in df.columns else df.copy()
        if '可交易标记' in df_filtered.columns:
            df_filtered = df_filtered[df_filtered['可交易标记'] == 1]
        return df_filtered


